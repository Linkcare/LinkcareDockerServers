FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Europe/Madrid

# ------------------------------------------------------
# Base system + repositories
# ------------------------------------------------------
RUN apt update && apt upgrade -y \
 && apt install -y --no-install-recommends \
    software-properties-common \
    ca-certificates \
    curl \
    wget \
    gnupg \
    unzip \
    lsb-release \
 && rm -rf /var/lib/apt/lists/*


# ------------------------------------------------------
# Apache (and modify default configuration to redirect error logs to Docker)
# ------------------------------------------------------
RUN apt update && apt install -y --no-install-recommends apache2 apache2-utils \
 && a2dismod mpm_event \
 && a2enmod mpm_prefork rewrite ssl \
 && sed -Ei 's|^(\s*)ErrorLog .*|\1ErrorLog /proc/self/fd/2|g' /etc/apache2/apache2.conf \
 && sed -Ei 's|^(\s*)CustomLog .*|\1#CustomLog /proc/self/fd/1 combined|g' /etc/apache2/apache2.conf \
 && { \
  echo '<VirtualHost *:80>'; \
  echo '  ServerAdmin webmaster@localhost'; \
  echo '  DocumentRoot /var/www/html'; \
  echo '  DirectoryIndex index.php index.html index.htm'; \
  echo '  <Directory /var/www/html>'; \
  echo '    AllowOverride All'; \
  echo '  </Directory>'; \
  echo '  ErrorLog /proc/self/fd/2'; \
  echo '</VirtualHost>'; \
  } > /etc/apache2/sites-available/000-default.conf \
 && rm -rf /var/www/html/* \
 && rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------
# PHP 8.3 + core extensions
# ------------------------------------------------------
RUN apt update && apt install -y \
    libapache2-mod-php8.3 \
    php8.3 \
    php8.3-cli \
    php8.3-common \
    php8.3-dev \
    php8.3-opcache \
    php8.3-mysql \
    php8.3-pgsql \
    php8.3-sqlite3 \
    php8.3-curl \
    php8.3-gd \
    php8.3-intl \
    php8.3-mbstring \
    php8.3-soap \
    php8.3-xml \
    php8.3-xsl \
    php8.3-zip \
    php8.3-bcmath \
    php8.3-bz2 \
    php8.3-exif \
    php8.3-calendar \
    php8.3-shmop \
    php8.3-redis \
    php-pear \
    build-essential \
 && rm -rf /var/lib/apt/lists/*


# ------------------------------------------------------
# Oracle Instant Client 21.9
# ------------------------------------------------------
COPY OracleClient/* /tmp/oracle/

RUN mkdir -p /usr/lib/oracle/21.9/client64 \
 && cd /usr/lib/oracle/21.9/client64 \
 && unzip /tmp/oracle/instantclient-basic-linux.x64-21.9.0.0.0dbru.zip \
 && unzip /tmp/oracle/instantclient-sdk-linux.x64-21.9.0.0.0dbru.zip \
 && mv instantclient_21_9 lib \
 && echo /usr/lib/oracle/21.9/client64/lib > /etc/ld.so.conf.d/oracle.conf \
 && apt update && apt install -y libaio1t64 \
 && ln -s /lib/x86_64-linux-gnu/libaio.so.1t64.0.2 /lib/x86_64-linux-gnu/libaio.so.1 \      
 && ldconfig

# ------------------------------------------------------
# OCI8 and OAuth (PECL)
# ------------------------------------------------------
RUN pecl channel-update pecl.php.net \
 && pecl install oci8 \
 && echo "extension=oci8" > /etc/php/8.3/mods-available/oci8.ini \
 && phpenmod oci8 \
 && pecl install oauth \
 && echo "extension=oauth" > /etc/php/8.3/mods-available/oauth.ini \
 && phpenmod oauth

# ------------------------------------------------------
# Runtime-only cleanup
# Remove compiler tools not necessary after build
# ------------------------------------------------------
RUN apt purge -y \
    build-essential \
    php8.3-dev \
    software-properties-common \
    gnupg \
    lsb-release \
 && apt autoremove -y \
 && rm -rf \
    /var/lib/apt/lists/* \
    /usr/share/doc/* \
    /usr/share/man/* \
    /usr/share/locale/* \
    /tmp/*

# ------------------------------------------------------
# wkhtmltopdf runtime dependency
# ------------------------------------------------------
RUN apt update && apt install -y libxext6 libxrender1 libfontconfig1 libfreetype6 libx11-6 xfonts-base xfonts-75dpi fonts-texgyre fonts-wqy-microhei ttf-wqy-microhei fonts-wqy-zenhei ttf-wqy-zenhei

# ------------------------------------------------------
# Composer
# ------------------------------------------------------
RUN curl -sS https://getcomposer.org/installer \
 | php -- --install-dir=/usr/bin --filename=composer

# ------------------------------------------------------
# Configure default memory and file upload limits
# Redirect PHP error logs to Docker
# ------------------------------------------------------
RUN { \
  echo 'upload_max_filesize = 8M'; \
  echo 'memory_limit = 256M'; \
  echo 'log_errors = On'; \
  echo 'error_log = /proc/self/fd/2'; \
  } > /etc/php/8.3/mods-available/lkconf.ini \
  && phpenmod lkconf

# ------------------------------------------------------
# Apache startup
# ------------------------------------------------------
COPY apache2-foreground /usr/local/bin/
RUN chmod +x /usr/local/bin/apache2-foreground

EXPOSE 80
CMD ["apache2-foreground"]
